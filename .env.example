# --- Data Lake (MinIO) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=minio_password
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=minio_password

# --- Lakehouse buckets ---
# Entities (tiki_products, tiki_categories, ...) live as prefixes inside these buckets.
BRONZE_BUCKET=bronze
SILVER_BUCKET=silver
LAKEHOUSE_BUCKET=lakehouse

# --- Crawler rotation budget ---
# How many leaf categories to crawl per daily run, and how deep per category.
# 50 leaves x 10 pages x ~3s delay = ~25min/run.
BUDGET_PER_RUN=50
PAGES_PER_CATEGORY=5

# Micro-batch availability: every N categories, crawler fires a `dbt run`
# against `path:models/staging` so silver tables become queryable mid-crawl
# without waiting for the full batch. Set 0 to disable (pure batch mode).
# The Airflow DAG sets this to 5 by default via task env.
TRIGGER_DBT_EVERY_N=0

# --- Airflow admin (consumed by airflow/start.sh inside container) ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@local

# --- Metastore & Backend (Postgres) ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin_password
POSTGRES_DB=metastore

# --- Visualization (Superset) ---
SUPERSET_SECRET_KEY=super_secret_lakehouse_key
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin_password

# --- Query Engine (Trino) ---
TRINO_USER=admin

# --- RAG chatbot ---
# Embedding runs locally via sentence-transformers — no API call. BGE-M3 is
# multilingual (good for Vietnamese) and outputs 1024-dim vectors.
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# Chat completion goes through an OpenAI-compatible LLM gateway (e.g. 9router
# running on the host, OpenRouter, the paid DeepSeek API, etc). When the
# gateway runs on the docker HOST, use http://host.docker.internal:<port>/v1 —
# the chatbot service has `extra_hosts: host.docker.internal:host-gateway` so
# it resolves on Linux too (Docker Desktop sets this automatically).
LLM_BASE_URL=http://host.docker.internal:20128/v1
LLM_API_KEY=sk-replace-with-your-own-key
CHAT_MODEL=gc/gemini-3-flash-preview